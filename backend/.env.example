# ── Personal / free-tier profile ───────────────────────────────────────────────
# For hobby hosting: set INLINE_PROCESSING=true and skip Redis/Celery entirely.
# Demo imagery works without object storage. Gemini is optional (rule-based fallback).

INLINE_PROCESSING=true

# ── Database (Neon free tier for cloud, or local Postgres) ───────────────────
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
SYNC_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Local Docker only:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/geospatial_db
# SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geospatial_db

# ── Redis / Celery (optional — only if INLINE_PROCESSING=false) ───────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Auth ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── Google Gemini (optional — free at aistudio.google.com) ────────────────────
GEMINI_API_KEY=

# ── Object Storage (optional — demo mode works without this) ──────────────────
STORAGE_BUCKET=
STORAGE_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
STORAGE_REGION=auto

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,https://YOUR_USERNAME.github.io
MAX_UPLOAD_MB=500
WORKER_CONCURRENCY=2
